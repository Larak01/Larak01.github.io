<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Lara Al Khatib — Data Analyst & AI</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,600;0,700;1,600&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --bg:        #f8f7f4;
      --surface:   #ffffff;
      --border:    #e4e1db;
      --accent:    #1a56db;
      --accent2:   #0e3a99;
      --text:      #111111;
      --body:      #444444;
      --muted:     #909090;
      --tag-bg:    #eef2ff;
      --tag-text:  #3730a3;
      --subtle:    #f3f2ef;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Inter', sans-serif;
      -webkit-font-smoothing: antialiased;
      line-height: 1.6;
    }

    /* ── NAV ── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      display: flex; justify-content: space-between; align-items: center;
      padding: 1.1rem 4rem;
      background: rgba(248,247,244,0.94);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--border);
    }
    .nav-logo {
      font-family: 'Playfair Display', serif;
      font-size: 1.1rem; font-weight: 700;
      color: var(--text);
    }
    .nav-links { display: flex; gap: 2rem; }
    .nav-links a {
      font-size: 0.78rem; font-weight: 500;
      color: var(--muted); text-decoration: none;
      letter-spacing: 0.06em; text-transform: uppercase;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--accent); }

    /* ── HERO ── */
    .hero {
      min-height: 100vh;
      display: flex; align-items: center;
      padding: 7rem 4rem 5rem;
      border-bottom: 1px solid var(--border);
    }
    .hero-inner {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 5rem; align-items: end;
      width: 100%; max-width: 1100px;
    }
    .hero-eyebrow {
      font-size: 0.74rem; font-weight: 600;
      color: var(--accent); letter-spacing: 0.16em;
      text-transform: uppercase; margin-bottom: 1.4rem;
      opacity: 0; animation: fadeUp 0.5s ease forwards 0.15s;
    }
    .hero h1 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2.6rem, 5vw, 4.8rem);
      font-weight: 700; line-height: 1.1;
      letter-spacing: -0.02em; color: var(--text);
      margin-bottom: 1.4rem;
      opacity: 0; animation: fadeUp 0.6s ease forwards 0.3s;
    }
    .hero h1 em { font-style: italic; color: var(--accent); }
    .hero-desc {
      max-width: 540px;
      font-size: 1rem; font-weight: 300;
      color: var(--body); line-height: 1.85;
      margin-bottom: 1rem;
      opacity: 0; animation: fadeUp 0.6s ease forwards 0.45s;
    }
    .hero-available {
      display: inline-block;
      font-size: 0.75rem; font-weight: 500;
      color: #166534; background: #dcfce7;
      border: 1px solid #bbf7d0;
      border-radius: 20px; padding: 0.3rem 0.9rem;
      margin-bottom: 2rem;
      opacity: 0; animation: fadeUp 0.6s ease forwards 0.55s;
    }
    .hero-available::before {
      content: '';
      display: inline-block; width: 6px; height: 6px;
      background: #16a34a; border-radius: 50%;
      margin-right: 0.5rem; vertical-align: middle;
    }
    .hero-cta {
      display: flex; gap: 1rem;
      opacity: 0; animation: fadeUp 0.6s ease forwards 0.65s;
    }
    .btn {
      padding: 0.78rem 1.9rem; border-radius: 6px;
      font-size: 0.84rem; font-weight: 500;
      letter-spacing: 0.02em; cursor: pointer;
      text-decoration: none; transition: all 0.2s ease;
      display: inline-block;
    }
    .btn-primary { background: var(--accent); color: #fff; border: 1.5px solid var(--accent); }
    .btn-primary:hover {
      background: var(--accent2); border-color: var(--accent2);
      transform: translateY(-1px);
      box-shadow: 0 4px 18px rgba(26,86,219,0.22);
    }
    .btn-ghost { background: transparent; color: var(--text); border: 1.5px solid var(--border); }
    .btn-ghost:hover { border-color: var(--accent); color: var(--accent); }

    .hero-stats {
      display: flex; flex-direction: column; gap: 2rem; align-items: flex-end;
      opacity: 0; animation: fadeUp 0.6s ease forwards 0.75s;
    }
    .stat-item { text-align: right; }
    .stat-num {
      font-family: 'Playfair Display', serif;
      font-size: 3rem; font-weight: 700;
      color: var(--text); line-height: 1;
    }
    .stat-num sup { font-size: 1.2rem; color: var(--accent); vertical-align: super; }
    .stat-label {
      font-size: 0.7rem; font-weight: 500;
      color: var(--muted); letter-spacing: 0.1em;
      text-transform: uppercase; margin-top: 0.3rem;
    }

    /* ── SHARED ── */
    .container { max-width: 1100px; margin: 0 auto; padding: 0 4rem; }
    section { border-bottom: 1px solid var(--border); }
    section:last-of-type { border-bottom: none; }

    .section-label {
      font-size: 0.7rem; font-weight: 600;
      color: var(--accent); letter-spacing: 0.18em;
      text-transform: uppercase; margin-bottom: 0.5rem;
    }
    .section-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.8rem, 3vw, 2.5rem);
      font-weight: 700; letter-spacing: -0.02em;
      line-height: 1.15; color: var(--text);
      margin-bottom: 2.5rem;
    }

    /* ── ABOUT ── */
    #about { padding: 6rem 0; }
    .about-grid {
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      gap: 6rem; align-items: start;
    }
    .about-body p {
      font-size: 0.975rem; font-weight: 300;
      color: var(--body); line-height: 1.9;
      margin-bottom: 1rem;
    }
    .about-body p strong { font-weight: 600; color: var(--text); }

    .info-list { display: flex; flex-direction: column; gap: 0.75rem; }
    .info-row {
      display: flex; align-items: center;
      gap: 0.9rem;
      font-size: 0.85rem; color: var(--body);
    }
    .info-row .info-icon {
      width: 32px; height: 32px;
      background: var(--subtle); border-radius: 6px;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .info-row svg { width: 15px; height: 15px; stroke: var(--accent); fill: none; stroke-width: 1.8; }
    .info-row a { color: var(--accent); text-decoration: none; }
    .info-row a:hover { text-decoration: underline; }

    /* ── EXPERIENCE ── */
    #experience { padding: 6rem 0; }
    .timeline { display: flex; flex-direction: column; gap: 2.5rem; }
    .timeline-item {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 2rem;
      padding-bottom: 2.5rem;
      border-bottom: 1px solid var(--border);
    }
    .timeline-item:last-child { border-bottom: none; padding-bottom: 0; }
    .exp-company {
      font-size: 0.7rem; font-weight: 600;
      color: var(--accent); letter-spacing: 0.12em;
      text-transform: uppercase; margin-bottom: 0.3rem;
    }
    .exp-role {
      font-family: 'Playfair Display', serif;
      font-size: 1.15rem; font-weight: 600;
      color: var(--text); margin-bottom: 0.75rem;
    }
    .exp-highlights { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; }
    .exp-highlights li {
      font-size: 0.875rem; font-weight: 300;
      color: var(--body); line-height: 1.75;
      padding-left: 1.1rem; position: relative;
    }
    .exp-highlights li::before {
      content: '';
      position: absolute; left: 0; top: 0.6em;
      width: 4px; height: 4px;
      background: var(--accent); border-radius: 50%;
    }
    .exp-highlights li strong { font-weight: 600; color: var(--text); }
    .exp-meta { text-align: right; flex-shrink: 0; }
    .exp-date {
      font-size: 0.8rem; font-weight: 500;
      color: var(--text); white-space: nowrap;
    }
    .exp-location {
      font-size: 0.75rem; color: var(--muted);
      margin-top: 0.25rem;
    }

    /* ── EDUCATION ── */
    #education { padding: 6rem 0; }
    .edu-list { display: flex; flex-direction: column; gap: 2rem; }
    .edu-item {
      display: grid; grid-template-columns: 1fr auto;
      gap: 2rem; padding-bottom: 2rem;
      border-bottom: 1px solid var(--border);
    }
    .edu-item:last-child { border-bottom: none; padding-bottom: 0; }
    .edu-degree {
      font-family: 'Playfair Display', serif;
      font-size: 1.05rem; font-weight: 600;
      color: var(--text); margin-bottom: 0.3rem;
    }
    .edu-school {
      font-size: 0.85rem; font-weight: 400;
      color: var(--body); margin-bottom: 0.4rem;
    }
    .edu-courses {
      font-size: 0.78rem; color: var(--muted);
      font-style: italic; line-height: 1.5;
    }
    .edu-meta { text-align: right; flex-shrink: 0; }
    .edu-date { font-size: 0.8rem; font-weight: 500; color: var(--text); white-space: nowrap; }
    .edu-place { font-size: 0.75rem; color: var(--muted); margin-top: 0.25rem; }

    /* ── PROJECTS ── */
    #projects { padding: 6rem 0; }
    .projects-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 1.4rem;
    }
    .project-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px; padding: 2rem;
      transition: all 0.25s ease;
      display: flex; flex-direction: column;
    }
    .project-card:hover {
      border-color: var(--accent);
      box-shadow: 0 6px 28px rgba(26,86,219,0.09);
      transform: translateY(-3px);
    }
    .project-category {
      font-size: 0.68rem; font-weight: 600;
      color: var(--accent); letter-spacing: 0.14em;
      text-transform: uppercase; margin-bottom: 0.7rem;
    }
    .project-name {
      font-family: 'Playfair Display', serif;
      font-size: 1.1rem; font-weight: 600;
      color: var(--text); margin-bottom: 0.75rem;
      line-height: 1.3;
    }
    .project-desc {
      font-size: 0.875rem; font-weight: 300;
      color: var(--body); line-height: 1.8;
      margin-bottom: 1.5rem; flex: 1;
    }
    .tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }
    .tag {
      font-size: 0.68rem; font-weight: 500;
      color: var(--tag-text); background: var(--tag-bg);
      border-radius: 4px; padding: 0.22rem 0.6rem;
    }

    /* ── SKILLS & CERTS ── */
    #skills { padding: 6rem 0; }
    .skills-layout {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }
    .skills-group-title {
      font-size: 0.78rem; font-weight: 600;
      color: var(--text); letter-spacing: 0.06em;
      text-transform: uppercase; margin-bottom: 1rem;
      padding-bottom: 0.6rem;
      border-bottom: 1px solid var(--border);
    }
    .skill-rows { display: flex; flex-direction: column; gap: 0.7rem; margin-bottom: 2.5rem; }
    .skill-row {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 7px; padding: 0.9rem 1.1rem;
      transition: border-color 0.2s, box-shadow 0.2s;
    }
    .skill-row:hover { border-color: var(--accent); box-shadow: 0 2px 12px rgba(26,86,219,0.07); }
    .skill-name { font-size: 0.82rem; font-weight: 600; color: var(--text); margin-bottom: 0.2rem; }
    .skill-tools { font-size: 0.76rem; color: var(--muted); }

    .cert-list { display: flex; flex-direction: column; gap: 0.7rem; }
    .cert-item {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 7px; padding: 0.9rem 1.1rem;
      transition: border-color 0.2s;
    }
    .cert-item:hover { border-color: var(--accent); }
    .cert-name { font-size: 0.82rem; font-weight: 600; color: var(--text); }
    .cert-issuer { font-size: 0.74rem; color: var(--muted); margin-top: 0.2rem; }

    /* ── LANGUAGES & INTERESTS ── */
    #extras { padding: 6rem 0; }
    .extras-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; }
    .lang-list { display: flex; flex-direction: column; gap: 0.7rem; }
    .lang-item {
      display: flex; justify-content: space-between; align-items: center;
      padding: 0.85rem 1.1rem;
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 7px;
    }
    .lang-name { font-size: 0.85rem; font-weight: 600; color: var(--text); }
    .lang-level { font-size: 0.76rem; color: var(--muted); }
    .interest-list { display: flex; flex-wrap: wrap; gap: 0.6rem; align-content: flex-start; }
    .interest-chip {
      font-size: 0.8rem; font-weight: 500;
      color: var(--body); background: var(--surface);
      border: 1px solid var(--border); border-radius: 20px;
      padding: 0.4rem 1rem;
      transition: border-color 0.2s;
    }
    .interest-chip:hover { border-color: var(--accent); color: var(--accent); }

    /* ── CONTACT ── */
    #contact { padding: 6rem 0; }
    .contact-inner { max-width: 600px; }
    .contact-intro {
      font-size: 0.975rem; font-weight: 300;
      color: var(--body); line-height: 1.85;
      margin-bottom: 2rem;
    }
    .email-card {
      display: flex; align-items: center;
      justify-content: space-between;
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 10px; padding: 1.3rem 1.6rem;
      margin-bottom: 1.6rem;
      transition: border-color 0.2s, box-shadow 0.2s;
    }
    .email-card:hover { border-color: var(--accent); box-shadow: 0 4px 16px rgba(26,86,219,0.07); }
    .email-label { font-size: 0.68rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); margin-bottom: 0.3rem; }
    .email-address { font-size: 0.975rem; font-weight: 500; color: var(--text); }
    .email-copy {
      font-size: 0.73rem; font-weight: 500;
      color: var(--accent); cursor: pointer;
      background: var(--tag-bg); border: none;
      border-radius: 5px; padding: 0.45rem 0.9rem;
      transition: background 0.2s;
    }
    .email-copy:hover { background: #dde7ff; }
    .contact-links { display: flex; gap: 0.9rem; flex-wrap: wrap; }
    .contact-link {
      font-size: 0.82rem; font-weight: 500;
      color: var(--body); text-decoration: none;
      border: 1.5px solid var(--border);
      padding: 0.65rem 1.3rem; border-radius: 6px;
      transition: all 0.2s;
    }
    .contact-link:hover { color: var(--accent); border-color: var(--accent); }

    /* ── FOOTER ── */
    footer {
      padding: 1.8rem 4rem;
      border-top: 1px solid var(--border);
      display: flex; justify-content: space-between; align-items: center;
    }
    footer p { font-size: 0.78rem; color: var(--muted); }
    footer a { color: var(--accent); text-decoration: none; }

    /* ── ANIMATIONS ── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 820px) {
      nav { padding: 1rem 1.5rem; }
      .nav-links { gap: 1.2rem; }
      .hero { padding: 6rem 1.5rem 4rem; }
      .hero-inner { grid-template-columns: 1fr; gap: 2.5rem; }
      .hero-stats { flex-direction: row; align-items: flex-start; gap: 2rem; }
      .stat-item { text-align: left; }
      .container { padding: 0 1.5rem; }
      .about-grid, .skills-layout, .extras-grid { grid-template-columns: 1fr; gap: 3rem; }
      .timeline-item, .edu-item { grid-template-columns: 1fr; gap: 0.5rem; }
      .exp-meta, .edu-meta { text-align: left; }
      footer { flex-direction: column; gap: 0.4rem; padding: 1.5rem; text-align: center; }
    }
  </style>
</head>
